# ============================================
# FC Manager - Environment Variables
# ============================================

# Backend
PORT=4000
JWT_SECRET=generate-a-secure-random-string-at-least-32-characters-long
NODE_ENV=development

# ============================================
# CORS - Frontend URLs
# ============================================

# Local development URL
CLIENT_URL_DEV=http://localhost:5173

# Production frontend URL (Vercel or other hosting)
CLIENT_URL=http://localhost:5173

# App URL (used for email links)
APP_URL=http://localhost:5173

# ============================================
# Email Service (Resend)
# ============================================

# Get your API key from https://resend.com
# Free tier: 100 emails/month
RESEND_API_KEY=re_123456789

# Sender email (must be verified in Resend for production)
# For development, you can use:
# - "Onboarding <onboarding@resend.dev>" (free, pre-verified)
# - Your own domain after verifying it
SENDER_EMAIL=FC Manager <noreply@yourdomain.com>
